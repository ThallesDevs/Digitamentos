<UserControl x:Class="Digitamentos.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:oxy="http://oxyplot.org/wpf">
    <Grid>
        <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="50,20">
            <TextBlock Text="Resultado Final" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="40" HorizontalAlignment="Center" Margin="0,0,0,30">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Tempo Total" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Metrics.TotalTime, StringFormat='{}{0:mm\\:ss}'}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Precisão" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding AccuracyFormatted}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Velocidade" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding KpmFormatted}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Total de Teclas" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding RawFormatted}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
            </ui:SimpleStackPanel>
            
            <oxy:PlotView Model="{Binding SpeedChartModel}" Height="300" Margin="0,0,0,30" Background="Transparent"/>

            <Button Content="Voltar ao Início" Command="{Binding GoHomeCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Width="200"/>
        </StackPanel>
    </Grid>
</UserControl>
