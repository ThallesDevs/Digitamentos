<Window x:Class="Digitamentos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:Digitamentos.ViewModels"
        xmlns:views="clr-namespace:Digitamentos.Views"
        xmlns:models="clr-namespace:Digitamentos.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Digitamentos" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Icon="icon.ico">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:TypingViewModel}">
            <views:TypingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
            <views:ResultsView />
        </DataTemplate>
        <ObjectDataProvider x:Key="CursorShapeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:CursorShape"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ui:CommandBar Grid.Row="0">
            <ui:AppBarButton Icon="Setting" Label="Configurações" Click="ToggleSettings_Click"/>
        </ui:CommandBar>
        
        <ui:SplitView x:Name="SettingsSplitView" Grid.Row="1" DisplayMode="Overlay" PanePlacement="Right" OpenPaneLength="350">
            <ui:SplitView.Pane>
                <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Tipografia" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Fonte do Texto"/>
                        <ComboBox ItemsSource="{Binding AvailableFonts}" SelectedItem="{Binding Settings.FontFamily}" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Tamanho da Fonte"/>
                        <Slider Minimum="14" Maximum="32" Value="{Binding Settings.FontSize}" TickFrequency="2" IsSnapToTickEnabled="True" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Estilo do Cursor" Margin="0,10,0,0"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource CursorShapeEnum}}" SelectedItem="{Binding Settings.CursorShape}" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                        
                        <ui:ToggleSwitch Header="Animação Fluida do Cursor" IsOn="{Binding Settings.SmoothCursor}" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Temas &amp; Cores" FontSize="20" FontWeight="Bold" Margin="0,20,0,10"/>
                        
                        <TextBlock Text="Preset de Tema"/>
                        <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding Settings.ThemePreset}" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Cor de Fundo Customizada (Hex)"/>
                        <TextBox Text="{Binding Settings.CustomBackgroundHex}" ui:ControlHelper.PlaceholderText="#1E1E1E" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Cor do Texto Customizada (Hex)"/>
                        <TextBox Text="{Binding Settings.CustomForegroundHex}" ui:ControlHelper.PlaceholderText="#D4D4D4" Margin="0,0,0,15"/>

                        <Button Content="Salvar &amp; Aplicar" Command="{Binding ApplySettingsCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </ui:SplitView.Pane>
            
            <ui:SplitView.Content>
                <ContentControl Content="{Binding CurrentViewModel}" Margin="10"/>
            </ui:SplitView.Content>
        </ui:SplitView>
    </Grid>
</Window>
